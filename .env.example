# === Database ===
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=order_quan_balun
MYSQL_USER=order_app
MYSQL_PASSWORD=order_app_pass
MYSQL_HOST=localhost
MYSQL_PORT=3306

# === API (NestJS) ===
API_PORT=3001
NODE_ENV=development

# === Auth (F-17 JWT 7d cookie) ===
JWT_SECRET=replace-with-strong-random-256-bit-secret-CHANGE-ME
JWT_LIFETIME_DAYS=7
COOKIE_NAME=ssp_token
COOKIE_SECURE=false  # set true in production (HTTPS only)
BCRYPT_COST=10

# === Setup wizard guard (P01.D-24) ===
# Allow setup wizard only from this IP — comma-separated for multiple
SETUP_ALLOWED_IP=127.0.0.1,::1

# === CSRF Origin check (P01.D-12) ===
ALLOWED_ORIGIN=http://localhost:5173

# === FE (Vite) ===
VITE_API_BASE_URL=http://localhost:3001
