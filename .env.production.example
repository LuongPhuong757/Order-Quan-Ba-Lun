# Production environment variables.
# Copy thành .env.production rồi sửa secrets. KHÔNG commit .env.production lên git.
#
# Generate secrets: openssl rand -base64 48

# ─── Domain ────────────────────────────────────────────────
# Domain trỏ về IP VPS (qua A record DNS). Caddy auto cấp Let's Encrypt cert.
DOMAIN=quanbalun.com

# ─── MySQL ─────────────────────────────────────────────────
# Random 32+ ký tự cho root password
MYSQL_ROOT_PASSWORD=CHANGE_ME_random_64_chars
MYSQL_DATABASE=order_quan_balun
# User app — KHÔNG dùng default 'order_app' cho prod
MYSQL_USER=ordbl_app
MYSQL_PASSWORD=CHANGE_ME_random_32_chars

# ─── JWT ───────────────────────────────────────────────────
# CRITICAL: random 64+ ký tự, KHÔNG share. Đổi = mọi session hiện tại invalidate.
JWT_SECRET=CHANGE_ME_random_64_chars_openssl_rand_base64_48
JWT_LIFETIME_DAYS=7
COOKIE_NAME=ssp_token

# ─── Setup endpoint allowlist ──────────────────────────────
# IP của chủ quán (truy cập /setup tạo owner đầu tiên).
# Sau khi setup xong, có thể đổi về 127.0.0.1 để khoá.
# Nhiều IP cách dấu phẩy: 1.2.3.4,5.6.7.8
SETUP_ALLOWED_IP=YOUR_HOME_IP
