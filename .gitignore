# Python
__pycache__/
*.pyc
.venv/

# OS
Thumbs.db

# VG runtime DB + state (added during scope run)
.vg/events.db
.vg/events.jsonl
.vg/.repo-lock.json
.vg/current-run.json
.vg/.evidence-key
.vg/.session-context.json
.vg/validator-quarantine.json
.vg/blocks/
