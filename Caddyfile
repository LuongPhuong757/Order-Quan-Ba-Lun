# Caddy reverse proxy → API container.
#
# HTTP-only mode (chưa có domain): listen :80, không HTTPS.
# Khi có domain: đổi `:80` thành `{$DOMAIN}` + bỏ comment block HTTPS bên dưới.

:80 {
    # Logging (rotate tự động khi >10MB)
    log {
        output stdout
        format console
    }

    # Reverse proxy mọi request tới API container (API serve cả web SPA + endpoints)
    reverse_proxy api:3001 {
        # Forward client IP cho trust proxy (BE đọc req.ip cho rate limit + audit)
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers (HTTP — không HSTS vì chưa HTTPS)
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), camera=(self), microphone=()"
    }

    # Compression (gzip + zstd) — giảm 60-80% payload JSON
    encode zstd gzip
}

# ─── Khi có domain, switch sang HTTPS auto Let's Encrypt ───
# Thay block :80 trên bằng:
#
# {$DOMAIN} {
#     log { output stdout format console }
#     reverse_proxy api:3001 {
#         header_up X-Real-IP {remote_host}
