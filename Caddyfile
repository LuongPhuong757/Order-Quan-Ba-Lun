# Caddy reverse proxy → API container.
# HTTPS auto qua Let's Encrypt — Caddy tự cấp + renew cert.
# DOMAIN env (vd: quanbalun.site) — set ở .env.production.

{$DOMAIN}, www.{$DOMAIN} {
    log {
        output stdout
        format console
    }

    reverse_proxy api:3001 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers — có HSTS vì đã HTTPS
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), camera=(self), microphone=()"
    }

    # Compression — giảm 60-80% payload JSON
    encode zstd gzip
}
